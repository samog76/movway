# TMDB API key - get yours at https://www.themoviedb.org/settings/api
# Copy this file to .env and fill in your key.
# If omitted, a built-in fallback key is used for development convenience.
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Default embed provider for watch pages.
# Supported values: vidplus, vidsrc-embed
VITE_EMBED_API_PROVIDER=vidplus
